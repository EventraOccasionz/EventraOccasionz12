{
  "entities": {
    "Family": {
      "title": "Family Profile",
      "description": "Guest groups authorized via an access code slug",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "access_code": { "type": "string" },
        "slug": { "type": "string" },
        "max_guests": { "type": "integer" },
        "created_at": { "type": "string" },
        "guest_image": { "type": "string" },
        "custom_greeting": { "type": "string" },
        "custom_title": { "type": "string" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "size": { "type": "integer" },
              "url": { "type": "string" },
              "uploaded_at": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "access_code", "slug", "max_guests"]
    },
    "RSVP": {
      "title": "RSVP Details",
      "description": "Form inputs responding to invitation status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "family_id": { "type": "string" },
        "guest_name": { "type": "string" },
        "email": { "type": "string" },
        "attending": { "type": "boolean" },
        "total_guests": { "type": "integer" },
        "children_count": { "type": "integer" },
        "custom_notes": { "type": "string" },
        "events": { "type": "array" },
        "created_at": { "type": "string" }
      },
      "required": ["family_id", "guest_name", "email", "attending", "total_guests", "events"]
    },
    "TransportRequest": {
      "title": "Transport Request",
      "description": "Travel logistics requests from families",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "family_id": { "type": "string" },
        "mode": { "type": "string", "enum": ["Car", "Bus", "Train", "Flight"] },
        "need_cab": { "type": "boolean" },
        "pickup_location": { "type": "string" },
        "arrival_time": { "type": "string" },
        "details": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["family_id", "mode", "need_cab"]
    },
    "RoomBooking": {
      "title": "Room Booking",
      "description": "Assigned luxury rooms or suite allotments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "family_id": { "type": "string" },
        "hotel_name": { "type": "string" },
        "room_number": { "type": "string" },
        "check_in": { "type": "string" },
        "check_out": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Checked-in", "Checked-out"] },
        "created_at": { "type": "string" }
      },
      "required": ["family_id", "status"]
    },
    "RegisteredAccount": {
      "title": "Registered Account",
      "description": "Users and managers registered and logged in",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "passcode": { "type": "string" },
        "slug": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "Inquiry": {
      "title": "Business Inquiry",
      "description": "B2C client lead bookings collected via contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "service_selected": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Contacted", "Completed"] },
        "created_at": { "type": "string" }
      },
      "required": ["name", "email", "phone", "service_selected", "message", "status"]
    },
    "Service": {
      "title": "Service Offering",
      "description": "CMS-backed service details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cat": { "type": "string" },
        "ico": { "type": "string" },
        "name": { "type": "string" },
        "desc": { "type": "string" },
        "feats": { "type": "array" },
        "price": { "type": "string" },
        "order_index": { "type": "integer" },
        "visible": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["cat", "ico", "name", "desc", "feats", "order_index", "visible"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Portfolio visuals with fallbacks and upload support",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cat": { "type": "string" },
        "lbl": { "type": "string" },
        "bg": { "type": "string" },
        "image_url": { "type": "string" },
        "order_index": { "type": "integer" },
        "visible": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["cat", "lbl", "order_index", "visible"]
    },
    "AuditLog": {
      "title": "Administrative Audit Log",
      "description": "Logs tracking backend adjustments of system resources",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "action": { "type": "string" },
        "performer": { "type": "string" },
        "category": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["timestamp", "action", "performer", "category", "details"]
    },
    "VenueSetting": {
      "title": "Venue Map Setting",
      "description": "Geographical and interactive map configuration for the event venue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "venue_name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "google_maps_url": { "type": "string" },
        "interactive_map_url": { "type": "string" },
        "zoom": { "type": "integer" },
        "updated_at": { "type": "string" }
      },
      "required": ["venue_name", "address"]
    },
    "EventDetails": {
      "title": "Event Details",
      "description": "Granular parameters including budgets, tasks, vendors, and timelines per event workspace",
      "type": "object",
      "properties": {
        "tasks": { "type": "array" },
        "vendors": { "type": "array" },
        "budget": { "type": "object" },
        "timeline": { "type": "array" },
        "staff": { "type": "array" }
      }
    },
    "FCMToken": {
      "title": "FCM Token Registration",
      "description": "Registered devices for FCM web push notifications",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "familyId": { "type": "string" },
        "accountId": { "type": "string" },
        "name": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["token"]
    },
    "Category": {
      "title": "Master Category",
      "description": "Website top-level service categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "short_desc": { "type": "string" },
        "display_order": { "type": "integer" }
      },
      "required": ["name", "slug"]
    },
    "SubCategory": {
      "title": "Sub Category",
      "description": "Website service sub-categories nested inside top-level categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category_id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "short_desc": { "type": "string" },
        "display_order": { "type": "integer" }
      },
      "required": ["category_id", "name", "slug"]
    },
    "AboutSetting": {
      "title": "About Setting",
      "description": "Premium story details, founder info, features and key statistics for Eventra",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "founder_name": { "type": "string" },
        "founder_image": { "type": "string" },
        "team_image": { "type": "string" },
        "heading": { "type": "string" },
        "description": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "years_experience": { "type": "string" },
            "events_managed": { "type": "string" },
            "trusted_vendors": { "type": "string" },
            "happy_clients": { "type": "string" }
          }
        },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updated_at": { "type": "string" }
      },
      "required": ["founder_name", "heading", "description"]
    },
    "EventConfig": {
      "title": "Event Configuration",
      "description": "Settings for the digital invitation, functions timeline, countdown, and RSVP behavior",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invitation": {
          "type": "object",
          "properties": {
            "welcomeHeading": { "type": "string" },
            "partner1Name": { "type": "string" },
            "partner2Name": { "type": "string" },
            "invitationMessage": { "type": "string" },
            "backgroundMusic": { "type": "string" },
            "mainPhoto": { "type": "string" }
          }
        },
        "functions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "date": { "type": "string" },
              "startTime": { "type": "string" },
              "venueName": { "type": "string" },
              "description": { "type": "string" },
              "dressCode": { "type": "string" },
              "mapsLink": { "type": "string" },
              "visible": { "type": "boolean" },
              "thumbnail": { "type": "string" }
            }
          }
        },
        "countdown": {
          "type": "object",
          "properties": {
            "show": { "type": "boolean" },
            "heading": { "type": "string" },
            "date": { "type": "string" }
          }
        },
        "rsvp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "deadline": { "type": "string" },
            "questions": {
              "type": "object",
              "properties": {
                "attendance": { "type": "boolean" },
                "guests": { "type": "boolean" },
                "food": { "type": "boolean" },
                "travel": { "type": "boolean" },
                "notes": { "type": "boolean" }
              }
            }
          }
        },
        "updated_at": { "type": "string" }
      }
    },
    "GuestDocument": {
      "title": "Guest Document",
      "description": "Verification documents uploaded by guests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "integer" },
        "url": { "type": "string" },
        "uploaded_at": { "type": "string" },
        "verification_status": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] },
        "family_id": { "type": "string" },
        "guest_id": { "type": "string" },
        "family_name": { "type": "string" },
        "event_id": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "type", "size", "url", "uploaded_at", "verification_status", "family_id", "event_id"]
    }
  },
  "firestore": {
    "categories": {
      "schema": "Category",
      "description": "Master categories for dynamic website content"
    },
    "sub_categories": {
      "schema": "SubCategory",
      "description": "Subcategories for dynamic website content"
    },
    "fcm_tokens": {
      "schema": "FCMToken",
      "description": "Store registered FCM push delivery tokens"
    },
    "families": {
      "schema": "Family",
      "description": "Family groups authorised for private dashboards"
    },
    "rsvp": {
      "schema": "RSVP",
      "description": "Submitted RSVPs per specific guest family identity"
    },
    "transport_requests": {
      "schema": "TransportRequest",
      "description": "Transport arrangements logged by wedding/party events"
    },
    "room_bookings": {
      "schema": "RoomBooking",
      "description": "Hotel assignment details allocated by Event managers"
    },
    "registered_accounts": {
      "schema": "RegisteredAccount",
      "description": "Security profile registry tracking explicit Auth identities"
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Leads submitted via contact pages"
    },
    "services": {
      "schema": "Service",
      "description": "Offerings in the dynamic event catalog with editable CMS details"
    },
    "gallery_items": {
      "schema": "GalleryItem",
      "description": "Luxe images of portfolio categories"
    },
    "audit_logs": {
      "schema": "AuditLog",
      "description": "Internal logs documenting administrative events"
    },
    "venue_settings": {
      "schema": "VenueSetting",
      "description": "Customized venue location coordinates and map image source definitions"
    },
    "about_settings": {
      "schema": "AboutSetting",
      "description": "About settings details containing founder name, story description, statistics, features, and images."
    },
    "event_details": {
      "schema": "EventDetails",
      "description": "Granular parameters including budgets, tasks, vendors, and timelines per event workspace"
    },
    "event_configs": {
      "schema": "EventConfig",
      "description": "Custom configuration for the digital invitation, functions, and RSVP settings"
    },
    "guest_documents": {
      "schema": "GuestDocument",
      "description": "Verification documents uploaded by guests"
    }
  }
}
